{% extends 'base.html.twig' %}

{% block title %}Edycja Zasobu{% endblock %}

{% block body %}
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-6">
            <div class="card shadow-sm">
                <div class="card-header bg-white py-3">
                    <h2 class="h4 mb-0 text-secondary">Edytuj Zasób #{{ resource.id }}</h2>
                </div>
                <div class="card-body p-4">

                    {{ form_start(form) }}
                    {{ form_widget(form) }}

                    <div class="d-flex justify-content-between align-items-center mt-4 pt-3 border-top">
                        <a href="{{ path('app_resource_index') }}" class="btn btn-outline-secondary btn-sm">
                            &larr; Powrót do magazynu
                        </a>
                        <button class="btn btn-primary btn-sm">
                            Zapisz zasób
                        </button>
                    </div>
                    {{ form_end(form) }}

                </div>
            </div>
        </div>
    </div>
{% endblock %}
