{% extends 'base.html.twig' %}

{% block title %}Nowy Zasób{% endblock %}

{% block body %}
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-6">
            <div class="card shadow-sm rounded-3">
                <div class="card-header bg-white py-3">
                    <h2 class="h4 mb-0 text-secondary">Dodaj Nowy Zasób</h2>
                </div>
                <div class="card-body p-4">

                    {# Rozpoczęcie formularza #}
                    {{ form_start(form) }}

                    {# Renderowanie wszystkich pól automatycznie w stylu Bootstrap #}
                    {{ form_widget(form) }}

                    <div class="d-flex justify-content-between align-items-center mt-4 pt-3 border-top">
                        <a href="{{ path('app_resource_index') }}" class="btn btn-outline-secondary btn-sm">
                            &larr; Powrót do magazynu
                        </a>
                        <button class="btn btn-primary btn-sm">
                            Zapisz zasób
                        </button>
                    </div>

                    {# funkcja dorzuca ukryty token CSRF #}
                    {{ form_end(form) }}

                </div>
            </div>
        </div>
    </div>
{% endblock %}
