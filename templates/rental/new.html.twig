{% extends 'base.html.twig' %}

{% block title %}Nowe Wypożyczenie - MediaStream{% endblock %}

{% block body %}
    <div class="mb-8 bg-gradient-to-r from-slate-900 to-indigo-950 rounded-2xl p-6 md:p-8 text-white shadow-lg relative overflow-hidden">
        <div class="relative z-10">
            <h1 class="text-3xl font-extrabold tracking-tight">Kreator Wypożyczeń</h1>
            <p class="mt-2 text-indigo-200 max-w-xl text-sm md:text-base">Zarejestruj nowe wypożyczenie multimediów lub książek w systemie w czasie rzeczywistym.</p>
        </div>
        <div class="absolute right-0 bottom-0 top-0 opacity-10 flex items-center pr-12 hidden lg:flex">
            <i class="fa-solid fa-cart-plus text-[120px]"></i>
        </div>
    </div>

    <div class="max-w-2xl mx-auto bg-white border border-gray-100 rounded-2xl shadow-sm overflow-hidden p-6 md:p-8">
        <div class="flex items-center space-x-3 mb-6 border-b border-gray-100 pb-4">
            <div class="p-2.5 bg-indigo-50 text-indigo-600 rounded-xl">
                <i class="fa-solid fa-file-invoice text-xl"></i>
            </div>
            <div>
                <h2 class="text-lg font-bold text-gray-900">Dane nowego wypożyczenia</h2>
                <p class="text-xs text-gray-400">Wypełnij poniższe pola, aby zapisać transakcję</p>
            </div>
        </div>

        {{ form_start(form, {'attr': {'class': 'space-y-5'}}) }}

        <div>
            <label class="block text-xs font-bold text-gray-400 uppercase tracking-wider mb-2">
                <i class="fa-solid fa-book mr-1 text-indigo-500"></i> Wybierz zasób
            </label>
            {{ form_widget(form.resource) }}
            {{ form_errors(form.resource) }}
        </div>

        <div>
            <label class="block text-xs font-bold text-gray-400 uppercase tracking-wider mb-2">
                <i class="fa-solid fa-arrow-up-1-9 mr-1 text-indigo-500"></i> Ilość egzemplarzy
            </label>
            {{ form_widget(form.quantity) }}
            {{ form_errors(form.quantity) }}
        </div>

        <div class="pt-4 border-t border-gray-100 flex flex-col sm:flex-row items-center justify-between gap-3">
            <a href="{{ path('app_dashboard') }}" class="w-full sm:w-auto text-center px-4 py-2 border border-gray-200 hover:bg-gray-50 text-gray-600 rounded-xl text-sm font-semibold transition">
                <i class="fa-solid fa-arrow-left mr-1.5"></i> Anuluj i wróć
            </a>
            <button type="submit" class="w-full sm:w-auto bg-indigo-600 hover:bg-indigo-700 text-white px-6 py-2.5 rounded-xl text-sm font-semibold shadow-md shadow-indigo-100 transition flex items-center justify-center">
                <i class="fa-solid fa-check mr-2"></i> Zatwierdź wypożyczenie
            </button>
        </div>

        {{ form_end(form) }}
    </div>
{% endblock %}
