{% extends 'base.html.twig' %}

{% block title %}Konto użytkownika - Moje Wypożyczenia{% endblock %}

{% block body %}
    <div class="sm:flex sm:items-center sm:justify-between mb-8">
        <div>
            <h1 class="text-3xl font-bold text-gray-900 tracking-tight">Konto użytkownika</h1>
            <p class="mt-2 text-sm text-gray-600">Pełna lista transakcji oraz stan bieżących rezerwacji materiałów multimedialnych.</p>
        </div>
        <div class="mt-4 sm:mt-0">
            <a href="{{ path('app_rental_new') }}" class="inline-flex items-center justify-center bg-indigo-600 hover:bg-indigo-700 text-white px-4 py-2.5 border border-transparent rounded-xl font-semibold shadow-sm text-sm transition focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500">
                <i class="fa-solid fa-plus mr-2"></i> Utwórz nowe wypożyczenie
            </a>
        </div>
    </div>

    <div class="overflow-hidden border border-gray-200 sm:rounded-xl shadow-inner">
        <table class="min-w-full divide-y divide-gray-200">
            <thead class="bg-gray-50">
            <tr>
                <th scope="col" class="px-6 py-3 text-left text-xs font-bold text-gray-500 uppercase tracking-wider w-16">ID</th>
                <th scope="col" class="px-6 py-3 text-left text-xs font-bold text-gray-500 uppercase tracking-wider">Użytkownik</th>
                <th scope="col" class="px-6 py-3 text-left text-xs font-bold text-gray-500 uppercase tracking-wider">Tytuł zasobu</th>
                <th scope="col" class="px-6 py-3 text-center text-xs font-bold text-gray-500 uppercase tracking-wider">Ilość</th>
                <th scope="col" class="px-6 py-3 text-left text-xs font-bold text-gray-500 uppercase tracking-wider">Data wypożyczenia</th>
                <th scope="col" class="px-6 py-3 text-left text-xs font-bold text-gray-500 uppercase tracking-wider">Status zwrotu</th>
                <th scope="col" class="px-6 py-3 class= text-right text-xs font-bold text-gray-500 uppercase tracking-wider pr-8">Akcje</th>
            </tr>
            </thead>
            <tbody class="bg-white divide-y divide-gray-200">
            {% for rental in rentals %}
                <tr class="hover:bg-gray-50/70 transition">
                    <td class="px-6 py-4 whitespace-nowrap text-sm font-mono text-gray-400">#{{ rental.id }}</td>
                    <td class="px-6 py-4 whitespace-nowrap">
                        <div class="flex items-center space-x-2 text-sm font-medium text-gray-900">
                            <div class="w-7 h-7 bg-indigo-100 text-indigo-700 rounded-full flex items-center justify-center text-xs font-bold">
                                {{ rental.borrowerName|slice(0,2)|upper }}
                            </div>
                            <span>{{ rental.borrowerName }}</span>
                        </div>
                    </td>
                    <td class="px-6 py-4 whitespace-nowrap">
                        <div class="text-sm font-semibold text-gray-900">
                            {{ rental.resource ? rental.resource.Title : '<span class="text-red-500 italic">Zasób archiwalny / usunięty</span>' }}
                        </div>
                    </td>
                    <td class="px-6 py-4 whitespace-nowrap text-center">
                    <span class="inline-flex items-center px-2.5 py-1 rounded-full text-xs font-bold bg-blue-50 text-blue-700 border border-blue-200">
                        {{ rental.quantity }} szt.
                    </span>
                    </td>
                    <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">
                        <i class="fa-regular fa-calendar-check mr-1.5 text-gray-400"></i>{{ rental.rentedAt ? rental.rentedAt|date('Y-m-d H:i') : '-' }}
                    </td>
                    <td class="px-6 py-4 whitespace-nowrap">
                        {% if rental.returnedAt %}
                            <span class="inline-flex items-center px-3 py-1 rounded-lg text-xs font-semibold bg-emerald-50 text-emerald-700 border border-emerald-200">
                            <i class="fa-solid fa-check-double mr-1.5"></i> Zwrócono ({{ rental.returnedAt|date('Y-m-d') }})
                        </span>
                        {% else %}
                            <span class="inline-flex items-center px-3 py-1 rounded-lg text-xs font-semibold bg-amber-50 text-amber-700 border border-amber-200 animate-pulse">
                            <i class="fa-solid fa-hourglass-half mr-1.5"></i> W toku wypożyczenia
                        </span>
                        {% endif %}
                    </td>
                    <td class="px-6 py-4 whitespace-nowrap text-right text-sm font-medium pr-8 space-x-3">
                        <a href="{{ path('app_rental_show', {'id': rental.id}) }}" class="text-indigo-600 hover:text-indigo-900 hover:underline transition">
                            <i class="fa-solid fa-magnifying-glass"></i> Szczegóły
                        </a>
                        {% if is_granted('ROLE_ADMIN') %}
                            <a href="{{ path('app_rental_edit', {'id': rental.id}) }}" class="text-amber-600 hover:text-amber-900 hover:underline transition">
                                <i class="fa-solid fa-pen-to-square"></i> Edytuj
                            </a>
                        {% endif %}
                    </td>
                </tr>
            {% else %}
                <tr>
                    <td colspan="7" class="px-6 py-12 text-center text-sm text-gray-500">
                        <div class="flex flex-col items-center justify-center space-y-3">
                            <i class="fa-solid fa-tray text-4xl text-gray-300"></i>
                            <span class="italic font-medium">Brak aktywnych lub archiwalnych wypożyczeń na tym koncie.</span>
                        </div>
                    </td>
                </tr>
            {% endfor %}
            </tbody>
        </table>
    </div>
{% endblock %}
