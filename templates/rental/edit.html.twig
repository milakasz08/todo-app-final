{% extends 'base.html.twig' %}

{% block title %}Edycja Wypożyczenia{% endblock %}

{% block body %}
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-6">
            <div class="card shadow-sm">
                <div class="card-header bg-white py-3">
                    <h2 class="h4 mb-0 text-secondary">Edytuj Wypożyczenie #{{ rental.id }}</h2>
                </div>
                <div class="card-body p-4">

                    {# Start formularza #}
                    {{ form_start(form) }}

                    {# Renderuje wszystkie pola automatycznie w stylu Bootstrap 5 #}
                    {{ form_widget(form) }}

                    <div class="d-flex justify-content-between align-items-center mt-4 pt-3 border-top">
                        <a href="{{ path('app_rental_index') }}" class="btn btn-outline-secondary btn-sm">
                            &larr; Powrót do listy
                        </a>
                        <button class="btn btn-primary btn-sm">
                            Zapisz zmiany
                        </button>
                    </div>
                    {{ form_end(form) }}

                    {# Sekcja usuwania (jeśli jest osobny plik z przyciskiem delete) #}
                    {% if delete_form is defined %}
                        <div class="mt-3 text-center">
                            {{ include('rental/_delete_form.html.twig') }}
                        </div>
                    {% endif %}

                </div>
            </div>
        </div>
    </div>
{% endblock %}
